#!/usr/bin/env bash
{{ hash_header }}set -euo pipefail

IPSET_V4="ai_crawlers_v4"
IPSET_V6="ai_crawlers_v6"

ipset create "$IPSET_V4" hash:net family inet -exist
ipset create "$IPSET_V6" hash:net family inet6 -exist
ipset flush "$IPSET_V4"
ipset flush "$IPSET_V6"

{% for cidr in v4 %}
ipset add "$IPSET_V4" "{{ cidr }}" -exist
{% endfor %}
{% for cidr in v6 %}
ipset add "$IPSET_V6" "{{ cidr }}" -exist
{% endfor %}

iptables -C INPUT -m set --match-set "$IPSET_V4" src -j DROP 2>/dev/null || iptables -I INPUT -m set --match-set "$IPSET_V4" src -j DROP
ip6tables -C INPUT -m set --match-set "$IPSET_V6" src -j DROP 2>/dev/null || ip6tables -I INPUT -m set --match-set "$IPSET_V6" src -j DROP

